# ─────────────────────────────────────────────────────────────────────
#   Frontend (Vite) — exposed in browser, NEVER put secrets here
# ─────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Leave VITE_API_URL unset locally — Vite dev proxy forwards /api to localhost:5000.
# In production on Vercel, leave it unset too — same-origin /api/* hits the serverless function.
# Only set this if you deploy frontend and backend to different domains.
# VITE_API_URL=https://your-backend-url.example.com

# ─────────────────────────────────────────────────────────────────────
#   Backend (server/) — secrets, never sent to the browser
# ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# CORS allowlist (comma-separated full origins) — REQUIRED in production.
# Only requests from these origins can hit the API. localhost is auto-allowed
# when NODE_ENV != production. Wildcards / partial matches are NOT supported.
# Example for production:
#   ALLOWED_ORIGINS=https://proshno-shala.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=

# Supabase service-role key — bypasses RLS, server-only
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────────────
#   AI providers — fallback chain. Set as many as you have.
#   Order of preference (vision first, then text-only):
#     Vision: groq → openrouter → mistral → novita → huggingface
#     Text:   groq → sambanova → mistral → openrouter → cohere → novita → huggingface
#   At least ONE vision-capable key is required for image scan.
#   At least ONE text-capable key is required for book question generation.
# ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxx
OPENROUTER_API_KEY=sk-or-v1-xxx
MISTRAL_API_KEY=xxx
NOVITA_API_KEY=sk_xxx
HUGGINGFACE_API_KEY=hf_xxx
SAMBANOVA_API_KEY=xxx
COHERE_API_KEY=xxx
# Z.ai (Zhipu GLM) — paid, used as last-resort fallback
Z_API_KEY=xxx

# Optional: per-provider timeout in ms (default 4500). Lower = fail-fast to next provider.
# AI_PROVIDER_TIMEOUT_MS=4500

# Payment is handled manually (bKash/Nagad/Rocket) — admin verifies via /admin panel.
# No gateway keys required.
